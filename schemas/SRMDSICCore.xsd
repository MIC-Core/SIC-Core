<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified"
    xmlns:vc="http://www.w3.org/2007/XMLSchema-versioning" vc:minVersion="1.1"
    xmlns:srmd="http://ssp-standard.org/SSPTraceability1/SimulationResourceMetaData"
    xmlns:stc="http://ssp-standard.org/SSPTraceability1/SSPTraceabilityCommon"
    xmlns:ssc="http://ssp-standard.org/SSP1/SystemStructureCommon"
    xmlns:sch="http://purl.oclc.org/dsdl/schematron"
    xmlns:sqf="http://www.schematron-quickfix.com/validator/process"
    targetNamespace="http://ssp-standard.org/SSPTraceability1/SimulationResourceMetaData">

    <xs:include schemaLocation="https://modelica.github.io/ssp-ls-traceability/main/SRMD.xsd"/>

    <xs:annotation>
        <xs:appinfo>
            <sch:title>SIC Core Classification Checks</sch:title>
            <sch:ns uri="http://ssp-standard.org/SSPTraceability1/SimulationResourceMetaData" prefix="srmd"/>
            <sch:ns uri="http://ssp-standard.org/SSPTraceability1/SSPTraceabilityCommon" prefix="stc"/>

            <sch:pattern>
                <sch:title>SIC Core: Classification Presence</sch:title>
                <sch:let name="sic-core-type" value="'org.mic-core.sic-core'"/>
                <sch:rule context="/srmd:SimulationResourceMetaData" role="info">
                    <sch:assert test="count(stc:Classification[@type=$sic-core-type])=1">
                        Missing or more than one SIC Core classification.
                    </sch:assert>
                </sch:rule>
            </sch:pattern>
            <sch:pattern>
                <sch:title>SIC Core: Mandatory Attributes</sch:title>
                <sch:rule context="/srmd:SimulationResourceMetaData/stc:Classification[@type=$sic-core-type]">
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.simulation-task'] or stc:ClassificationEntry[@keyword='administrative.simulation-task.name'] or stc:ClassificationEntry[@keyword='administrative.simulation-task.version'] or stc:ClassificationEntry[@keyword='administrative.simulation-task.identifier']" sqf:fix="add-administrative-simulation-task">Missing mandatory Simulation Task attribute.</sch:assert>
                    <sqf:fix id="add-administrative-simulation-task"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="administrative.simulation-task">Value</stc:ClassificationEntry></sqf:add></sqf:fix>
                    <sch:assert test="not(stc:ClassificationEntry[@keyword='administrative.simulation-task'] and (stc:ClassificationEntry[@keyword='administrative.simulation-task.name'] or stc:ClassificationEntry[@keyword='administrative.simulation-task.version'] or stc:ClassificationEntry[@keyword='administrative.simulation-task.identifier']))">Use either the Simulation Task base attribute or the mandatory Simulation Task sub-attributes, but not both.</sch:assert>

                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.simulation-task'] or stc:ClassificationEntry[@keyword='administrative.simulation-task.name']" sqf:fix="add-administrative-simulation-task-name">Missing mandatory Simulation Task Name attribute.</sch:assert>
                    <sqf:fix id="add-administrative-simulation-task-name"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="administrative.simulation-task.name">Value</stc:ClassificationEntry></sqf:add></sqf:fix>

                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.simulation-task'] or stc:ClassificationEntry[@keyword='administrative.simulation-task.version']" sqf:fix="add-administrative-simulation-task-version">Missing mandatory Simulation Task Version attribute.</sch:assert>
                    <sqf:fix id="add-administrative-simulation-task-version"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="administrative.simulation-task.version">Value</stc:ClassificationEntry></sqf:add></sqf:fix>

                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.simulation-task'] or stc:ClassificationEntry[@keyword='administrative.simulation-task.identifier']" sqf:fix="add-administrative-simulation-task-identifier">Missing mandatory Simulation Task Identifier attribute.</sch:assert>
                    <sqf:fix id="add-administrative-simulation-task-identifier"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="administrative.simulation-task.identifier">Value</stc:ClassificationEntry></sqf:add></sqf:fix>

                    <sch:assert test="stc:ClassificationEntry[@keyword='analysis.item-under-test'] or stc:ClassificationEntry[@keyword='analysis.item-under-test.name'] or stc:ClassificationEntry[@keyword='analysis.item-under-test.version'] or stc:ClassificationEntry[@keyword='analysis.item-under-test.identifier']" sqf:fix="add-analysis-item-under-test">Missing mandatory Item under Test attribute.</sch:assert>
                    <sqf:fix id="add-analysis-item-under-test"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="analysis.item-under-test">Value</stc:ClassificationEntry></sqf:add></sqf:fix>
                    <sch:assert test="not(stc:ClassificationEntry[@keyword='analysis.item-under-test'] and (stc:ClassificationEntry[@keyword='analysis.item-under-test.name'] or stc:ClassificationEntry[@keyword='analysis.item-under-test.version'] or stc:ClassificationEntry[@keyword='analysis.item-under-test.identifier']))">Use either the Item under Test base attribute or the mandatory Item under Test sub-attributes, but not both.</sch:assert>

                    <sch:assert test="stc:ClassificationEntry[@keyword='analysis.item-under-test'] or stc:ClassificationEntry[@keyword='analysis.item-under-test.name']" sqf:fix="add-analysis-item-under-test-name">Missing mandatory Item under Test Name attribute.</sch:assert>
                    <sqf:fix id="add-analysis-item-under-test-name"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="analysis.item-under-test.name">Value</stc:ClassificationEntry></sqf:add></sqf:fix>

                    <sch:assert test="stc:ClassificationEntry[@keyword='analysis.item-under-test'] or stc:ClassificationEntry[@keyword='analysis.item-under-test.version']" sqf:fix="add-analysis-item-under-test-version">Missing mandatory Item under Test Version attribute.</sch:assert>
                    <sqf:fix id="add-analysis-item-under-test-version"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="analysis.item-under-test.version">Value</stc:ClassificationEntry></sqf:add></sqf:fix>

                    <sch:assert test="stc:ClassificationEntry[@keyword='analysis.item-under-test'] or stc:ClassificationEntry[@keyword='analysis.item-under-test.identifier']" sqf:fix="add-analysis-item-under-test-identifier">Missing mandatory Item under Test Identifier attribute.</sch:assert>
                    <sqf:fix id="add-analysis-item-under-test-identifier"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="analysis.item-under-test.identifier">Value</stc:ClassificationEntry></sqf:add></sqf:fix>

                    <sch:assert test="stc:ClassificationEntry[@keyword='analysis.simulation-task.objectives']" sqf:fix="add-analysis-simulation-task-objectives">Missing mandatory Simulation Objective attribute.</sch:assert>
                    <sqf:fix id="add-analysis-simulation-task-objectives"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="analysis.simulation-task.objectives">Value</stc:ClassificationEntry></sqf:add></sqf:fix>

                    <sch:assert test="stc:ClassificationEntry[@keyword='requirements.parameters.subject-information.parametrized-entity']" sqf:fix="add-requirements-parameters-subject-information-parametrized-entity">Missing mandatory Entity Parameter attribute.</sch:assert>
                    <sqf:fix id="add-requirements-parameters-subject-information-parametrized-entity"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="requirements.parameters.subject-information.parametrized-entity">Value</stc:ClassificationEntry></sqf:add></sqf:fix>

                    <sch:assert test="stc:ClassificationEntry[@keyword='execution.model'] or stc:ClassificationEntry[@keyword='execution.model.names'] or stc:ClassificationEntry[@keyword='execution.model.version'] or stc:ClassificationEntry[@keyword='execution.model.identifier']" sqf:fix="add-execution-model">Missing mandatory Used Simulation Model attribute.</sch:assert>
                    <sqf:fix id="add-execution-model"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="execution.model">Value</stc:ClassificationEntry></sqf:add></sqf:fix>
                    <sch:assert test="not(stc:ClassificationEntry[@keyword='execution.model'] and (stc:ClassificationEntry[@keyword='execution.model.names'] or stc:ClassificationEntry[@keyword='execution.model.version'] or stc:ClassificationEntry[@keyword='execution.model.identifier']))">Use either the Used Simulation Model base attribute or the mandatory Used Simulation Model sub-attributes, but not both.</sch:assert>

                    <sch:assert test="stc:ClassificationEntry[@keyword='execution.model'] or stc:ClassificationEntry[@keyword='execution.model.names']" sqf:fix="add-execution-model-names">Missing mandatory Used Simulation Model Name attribute.</sch:assert>
                    <sqf:fix id="add-execution-model-names"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="execution.model.names">Value</stc:ClassificationEntry></sqf:add></sqf:fix>

                    <sch:assert test="stc:ClassificationEntry[@keyword='execution.model'] or stc:ClassificationEntry[@keyword='execution.model.version']" sqf:fix="add-execution-model-version">Missing mandatory Used Simulation Model Version attribute.</sch:assert>
                    <sqf:fix id="add-execution-model-version"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="execution.model.version">Value</stc:ClassificationEntry></sqf:add></sqf:fix>

                    <sch:assert test="stc:ClassificationEntry[@keyword='execution.model'] or stc:ClassificationEntry[@keyword='execution.model.identifier']" sqf:fix="add-execution-model-identifier">Missing mandatory Used Simulation Model Identifier attribute.</sch:assert>
                    <sqf:fix id="add-execution-model-identifier"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="execution.model.identifier">Value</stc:ClassificationEntry></sqf:add></sqf:fix>

                    <sch:assert test="stc:ClassificationEntry[@keyword='execution.parameters'] or stc:ClassificationEntry[@keyword='execution.parameters.names'] or stc:ClassificationEntry[@keyword='execution.parameters.version'] or stc:ClassificationEntry[@keyword='execution.parameters.identifier']" sqf:fix="add-execution-parameters">Missing mandatory Used Parameter attribute.</sch:assert>
                    <sqf:fix id="add-execution-parameters"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="execution.parameters">Value</stc:ClassificationEntry></sqf:add></sqf:fix>
                    <sch:assert test="not(stc:ClassificationEntry[@keyword='execution.parameters'] and (stc:ClassificationEntry[@keyword='execution.parameters.names'] or stc:ClassificationEntry[@keyword='execution.parameters.version'] or stc:ClassificationEntry[@keyword='execution.parameters.identifier']))">Use either the Used Parameter base attribute or the mandatory Used Parameter sub-attributes, but not both.</sch:assert>

                    <sch:assert test="stc:ClassificationEntry[@keyword='execution.parameters'] or stc:ClassificationEntry[@keyword='execution.parameters.names']" sqf:fix="add-execution-parameters-names">Missing mandatory Used Parameter Name attribute.</sch:assert>
                    <sqf:fix id="add-execution-parameters-names"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="execution.parameters.names">Value</stc:ClassificationEntry></sqf:add></sqf:fix>

                    <sch:assert test="stc:ClassificationEntry[@keyword='execution.parameters'] or stc:ClassificationEntry[@keyword='execution.parameters.version']" sqf:fix="add-execution-parameters-version">Missing mandatory Used Parameter Version attribute.</sch:assert>
                    <sqf:fix id="add-execution-parameters-version"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="execution.parameters.version">Value</stc:ClassificationEntry></sqf:add></sqf:fix>

                    <sch:assert test="stc:ClassificationEntry[@keyword='execution.parameters'] or stc:ClassificationEntry[@keyword='execution.parameters.identifier']" sqf:fix="add-execution-parameters-identifier">Missing mandatory Used Parameter Identifier attribute.</sch:assert>
                    <sqf:fix id="add-execution-parameters-identifier"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="execution.parameters.identifier">Value</stc:ClassificationEntry></sqf:add></sqf:fix>

                    <sch:assert test="stc:ClassificationEntry[@keyword='execution.tool'] or stc:ClassificationEntry[@keyword='execution.tool.name'] or stc:ClassificationEntry[@keyword='execution.tool.version'] or stc:ClassificationEntry[@keyword='execution.tool.identifier']" sqf:fix="add-execution-tool">Missing mandatory Used Tool attribute.</sch:assert>
                    <sqf:fix id="add-execution-tool"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="execution.tool">Value</stc:ClassificationEntry></sqf:add></sqf:fix>
                    <sch:assert test="not(stc:ClassificationEntry[@keyword='execution.tool'] and (stc:ClassificationEntry[@keyword='execution.tool.name'] or stc:ClassificationEntry[@keyword='execution.tool.version'] or stc:ClassificationEntry[@keyword='execution.tool.identifier']))">Use either the Used Tool base attribute or the mandatory Used Tool sub-attributes, but not both.</sch:assert>

                    <sch:assert test="stc:ClassificationEntry[@keyword='execution.tool'] or stc:ClassificationEntry[@keyword='execution.tool.name']" sqf:fix="add-execution-tool-name">Missing mandatory Used Tool Name attribute.</sch:assert>
                    <sqf:fix id="add-execution-tool-name"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="execution.tool.name">Value</stc:ClassificationEntry></sqf:add></sqf:fix>

                    <sch:assert test="stc:ClassificationEntry[@keyword='execution.tool'] or stc:ClassificationEntry[@keyword='execution.tool.version']" sqf:fix="add-execution-tool-version">Missing mandatory Used Tool Version attribute.</sch:assert>
                    <sqf:fix id="add-execution-tool-version"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="execution.tool.version">Value</stc:ClassificationEntry></sqf:add></sqf:fix>

                    <sch:assert test="stc:ClassificationEntry[@keyword='execution.tool'] or stc:ClassificationEntry[@keyword='execution.tool.identifier']" sqf:fix="add-execution-tool-identifier">Missing mandatory Used Tool Identifier attribute.</sch:assert>
                    <sqf:fix id="add-execution-tool-identifier"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="execution.tool.identifier">Value</stc:ClassificationEntry></sqf:add></sqf:fix>

                    <sch:assert test="stc:ClassificationEntry[@keyword='fulfillment.task-status']" sqf:fix="add-fulfillment-task-status">Missing mandatory Task Status attribute.</sch:assert>
                    <sqf:fix id="add-fulfillment-task-status"><sqf:description><sqf:title>Add missing classification entry</sqf:title></sqf:description><sqf:add position="last-child"><stc:ClassificationEntry keyword="fulfillment.task-status">Value</stc:ClassificationEntry></sqf:add></sqf:fix>
                </sch:rule>
            </sch:pattern>
            <sch:pattern>
                <sch:title>SIC Core: Recommended Attributes</sch:title>
                <sch:rule context="/srmd:SimulationResourceMetaData/stc:Classification[@type=$sic-core-type]" role="info">
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.overall-product'] or stc:ClassificationEntry[starts-with(@keyword, 'administrative.overall-product.')]">Missing recommended Overall Product attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.overall-product'] or stc:ClassificationEntry[@keyword='administrative.overall-product.name']">Missing recommended Overall Product Name attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.overall-product'] or stc:ClassificationEntry[@keyword='administrative.overall-product.version']">Missing recommended Overall Product Version attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.overall-product'] or stc:ClassificationEntry[@keyword='administrative.overall-product.identifier']">Missing recommended Overall Product Identifier attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.specific-product'] or stc:ClassificationEntry[starts-with(@keyword, 'administrative.specific-product.')]">Missing recommended Specific Product attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.specific-product'] or stc:ClassificationEntry[@keyword='administrative.specific-product.name']">Missing recommended Specific Product Name attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.specific-product'] or stc:ClassificationEntry[@keyword='administrative.specific-product.version']">Missing recommended Specific Product Version attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.specific-product'] or stc:ClassificationEntry[@keyword='administrative.specific-product.identifier']">Missing recommended Specific Product Identifier attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.ordering-project'] or stc:ClassificationEntry[starts-with(@keyword, 'administrative.ordering-project.')]">Missing recommended Ordering Project attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.ordering-project'] or stc:ClassificationEntry[@keyword='administrative.ordering-project.name']">Missing recommended Ordering Project Name attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.ordering-project'] or stc:ClassificationEntry[@keyword='administrative.ordering-project.version']">Missing recommended Ordering Project Version attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.ordering-project'] or stc:ClassificationEntry[@keyword='administrative.ordering-project.identifier']">Missing recommended Ordering Project Identifier attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.simulation-request'] or stc:ClassificationEntry[starts-with(@keyword, 'administrative.simulation-request.')]">Missing recommended Simulation Request attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.simulation-request'] or stc:ClassificationEntry[@keyword='administrative.simulation-request.name']">Missing recommended Simulation Request Name attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.simulation-request'] or stc:ClassificationEntry[@keyword='administrative.simulation-request.version']">Missing recommended Simulation Request Version attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.simulation-request'] or stc:ClassificationEntry[@keyword='administrative.simulation-request.identifier']">Missing recommended Simulation Request Identifier attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.simulation-task'] or stc:ClassificationEntry[@keyword='administrative.simulation-task.confidentiality']">Missing recommended Simulation Task Confidentiality Level attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.simulation-task'] or stc:ClassificationEntry[@keyword='administrative.simulation-task.date.start']">Missing recommended Predicted Simulation Start Date attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.simulation-task'] or stc:ClassificationEntry[@keyword='administrative.simulation-task.date.delivery']">Missing recommended Requested Simulation Delivery Date attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.contact.customer-person']">Missing recommended Requesting Person attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.contact.customer-entity']">Missing recommended Requesting Entity attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.contact.contractor-person']">Missing recommended Contracting Person attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='administrative.contact.contractor-entity']">Missing recommended Contracting Entity attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='analysis.engineering-task.higher-level'] or stc:ClassificationEntry[starts-with(@keyword, 'analysis.engineering-task.higher-level.')]">Missing recommended Higher Level Engineering Task attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='analysis.engineering-task.higher-level'] or stc:ClassificationEntry[@keyword='analysis.engineering-task.higher-level.name']">Missing recommended Higher Level Engineering Task Name attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='analysis.engineering-task.higher-level'] or stc:ClassificationEntry[@keyword='analysis.engineering-task.higher-level.version']">Missing recommended Higher Level Engineering Task Version attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='analysis.engineering-task.higher-level'] or stc:ClassificationEntry[@keyword='analysis.engineering-task.higher-level.identifier']">Missing recommended Higher Level Engineering Task Identifier attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='analysis.engineering-task.specific'] or stc:ClassificationEntry[starts-with(@keyword, 'analysis.engineering-task.specific.')]">Missing recommended Specific Engineering Task attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='analysis.engineering-task.specific'] or stc:ClassificationEntry[@keyword='analysis.engineering-task.specific.name']">Missing recommended Specific Engineering Task Name attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='analysis.engineering-task.specific'] or stc:ClassificationEntry[@keyword='analysis.engineering-task.specific.version']">Missing recommended Specific Engineering Task Version attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='analysis.engineering-task.specific'] or stc:ClassificationEntry[@keyword='analysis.engineering-task.specific.identifier']">Missing recommended Specific Engineering Task Identifier attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='analysis.simulation-task.further-requirements']">Missing recommended Simulation further Requirements attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='analysis.quality-aspects']">Missing recommended Quality Criterion attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='analysis.verification']">Missing recommended Verification Criterion attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='analysis.validation']">Missing recommended Validation Criterion attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='requirements.models.purpose-objectives']">Missing recommended Model Purpose and Objectives attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='requirements.models.subject-information.modeled-entity'] or stc:ClassificationEntry[starts-with(@keyword, 'requirements.models.subject-information.modeled-entity.')]">Missing recommended Modeled Entity attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='requirements.models.subject-information.modeled-entity'] or stc:ClassificationEntry[@keyword='requirements.models.subject-information.modeled-entity.name']">Missing recommended Modeled Entity Name attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='requirements.models.subject-information.modeled-entity'] or stc:ClassificationEntry[@keyword='requirements.models.subject-information.modeled-entity.version']">Missing recommended Modeled Entity Version attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='requirements.models.subject-information.modeled-entity'] or stc:ClassificationEntry[@keyword='requirements.models.subject-information.modeled-entity.identifier']">Missing recommended Modeled Entity Identifier attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='requirements.model.effects-considered']">Missing recommended Required Modeled Effect attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='requirements.model.further-model-requirements']">Missing recommended Further Model Requirements attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='requirements.model.confidentiality']">Missing recommended Simulation Model Confidentiality Level attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='requirements.parameter-value-distribution-function']">Missing recommended Value Distribution Function attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='requirements.parameter.confidentiality']">Missing recommended Parameter Confidentiality Level attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='requirements.test-case'] or stc:ClassificationEntry[starts-with(@keyword, 'requirements.test-case.')]">Missing recommended Test Case Requirements attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='requirements.test-case'] or stc:ClassificationEntry[@keyword='requirements.test-case.confidentiality']">Missing recommended Test Case Confidentiality Level attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='requirements.simulation-environment']">Missing recommended Simulation Environment Requirement attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='requirements.simulation-integration']">Missing recommended Simulation Integration Requirement attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='requirements.quality-assurance']">Missing recommended Quality Assurance Requirements attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='requirements.verification']">Missing recommended Requirements Phase Verification Result attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='design.model']">Missing recommended Model Design Specification attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='design.parameter']">Missing recommended Parameter Design Specification attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='design.test-case']">Missing recommended Test Case Design Specification attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='design.simulation-environment']">Missing recommended Simulation Environment Design Specification attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='design.simulation-integration']">Missing recommended Simulation Integration Design Specification attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='design.quality-assurance']">Missing recommended Design Quality Assurance attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='design.verification']">Missing recommended Design Verification Result attribute.</sch:assert>
                    <sch:assert test="stc:ClassificationEntry[@keyword='implementation.model'] or stc:ClassificationEntry[starts-with(@keyword, 'implementation.model.')]">Missing recommended Simulation Model attribute.</sch:assert>
