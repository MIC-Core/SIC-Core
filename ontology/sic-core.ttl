@prefix sic:   <https://mic-core.org/ontology/sic-core#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix vann:  <http://purl.org/vocab/vann/> .

<https://mic-core.org/ontology/sic-core>
    a owl:Ontology ;
    rdfs:label "SIC Core Ontology"@en ;
    rdfs:comment "OWL ontology for the Simulation Information Card (SIC) Core specification."@en ;
    dcterms:title "SIC Core Ontology"@en ;
    dcterms:description "This ontology formalises the SIC Core attribute set so that simulation-task metadata can be expressed, exchanged and validated in standard Semantic-Web formats (RDF/OWL, SHACL, JSON-LD)."@en ;
    dcterms:creator "IRT SystemX and prostep ivip" ;
    vann:preferredNamespacePrefix "sic" ;
    vann:preferredNamespaceUri "https://mic-core.org/ontology/sic-core#" ;
    owl:versionInfo "1.0" .

sic:SimulationTask
    a owl:Class ;
    rdfs:label "Simulation Task"@en ;
    rdfs:comment "A simulation task described by SIC Core metadata attributes."@en .

sic:administrativeOverallProduct
    a owl:DatatypeProperty ;
    rdfs:label "Overall Product"@en ;
    rdfs:comment "Administrative Data attribute mapped from SIC Core to SRMD keyword administrative.overall-product."@en ;
    rdfs:domain sic:SimulationTask ;
    rdfs:range xsd:string ;
    skos:note "Obligation: Recommended. Multiple values allowed."@en ;
    skos:mappingRelation "SRMD classification keyword: administrative.overall-product"@en .

sic:administrativeOverallProductName
    a owl:DatatypeProperty ;
