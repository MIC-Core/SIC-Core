        sh:name "Fulfillment Date" ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
        sh:severity sh:Warning ;
        sh:message "sic:fulfillmentDate is recommended and may appear at most once."@en ;
    ] .

