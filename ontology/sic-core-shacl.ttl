@prefix sic:   <https://mic-core.org/ontology/sic-core#> .
@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<https://mic-core.org/ontology/sic-core-shacl>
    a owl:Ontology ;
    rdfs:label "SIC Core SHACL Shapes"@en ;
    rdfs:comment "SHACL shapes for validating simulation-task metadata against the SIC Core specification."@en ;
    dcterms:creator "IRT SystemX and prostep ivip" ;
    owl:imports <https://mic-core.org/ontology/sic-core> ;
    owl:versionInfo "1.0" .

sic:SimulationTaskShape
    a sh:NodeShape ;
    sh:targetClass sic:SimulationTask ;
    rdfs:label "SimulationTask Shape"@en ;
    rdfs:comment "Validates that a sic:SimulationTask instance carries the required SIC Core metadata attributes."@en ;

    sh:property [
        sh:path sic:administrativeOverallProduct ;
        sh:name "Overall Product" ;
        sh:datatype xsd:string ;
        sh:severity sh:Warning ;
        sh:message "sic:administrativeOverallProduct is recommended."@en ;
    ] ;

    sh:property [
        sh:path sic:administrativeOverallProductName ;
        sh:name "Overall Product Name" ;
        sh:datatype xsd:string ;
        sh:severity sh:Warning ;
        sh:message "sic:administrativeOverallProductName is recommended."@en ;
    ] ;

    sh:property [
